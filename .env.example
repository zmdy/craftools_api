# Copie este arquivo para ".env" (mesma pasta) e ajuste os valores.
# O ".env" real NUNCA deve ser commitado — já está no .gitignore.

# Exibe erros na tela (apenas em desenvolvimento local). 0 em produção.
APP_DEBUG=0

# Fuso horário usado em timestamps gerados pela aplicação.
APP_TIMEZONE=America/Sao_Paulo

# Origem permitida para CORS nas APIs públicas (/api e /v1).
# Use o domínio do seu PWA em produção, ex: https://app.seudominio.com
# "*" funciona mas é menos seguro (qualquer site pode chamar a API).
API_ALLOWED_ORIGIN=*

# Limites do rate limiter das APIs públicas.
API_RATE_LIMIT_PER_IP=120
API_RATE_LIMIT_WINDOW_SECONDS=60
