# craftools_api/.htaccess
#
# Camada de defesa extra para hospedagens compartilhadas onde NÃO é possível
# apontar o DocumentRoot direto para craftools_api/public/ (cenário ideal —
# ver README.md). Se a pasta craftools_api inteira ficar acessível pela web,
# esta regra bloqueia qualquer acesso a tudo que não esteja dentro de public/.
#
# Se o seu provedor permitir configurar o DocumentRoot para apontar
# diretamente para "public/", este arquivo é redundante mas inofensivo.

<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>

<Files ~ "\.(php|sql|json|env|md)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</Files>
