# craftools_api/.htaccess
#
# Regras de roteamento para permitir que o sistema funcione corretamente
# quando instalado dentro de uma subpasta (ex: public_html/craftools_api/)
# sem precisar apontar o DocumentRoot diretamente para a pasta public/.

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^$ public/ [L]
    RewriteCond %{REQUEST_URI} !public/
    RewriteRule (.*) public/$1 [L]
</IfModule>

# Bloqueia acesso direto aos arquivos de configuração e documentação na raiz
<FilesMatch "^\.env|^\.gitignore|README\.md|\.sql$|\.json$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
