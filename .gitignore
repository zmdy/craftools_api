.env
.DS_Store

# Runtime SQLite database (auto-created from database/schema.sql on first run)
storage/*.sqlite
storage/*.sqlite-*

# Logs
storage/logs/*.log
!storage/logs/.gitkeep

# Uploaded/migrated source images (kept out of version control; only the
# generated .webp assets under public/api/assets are served at runtime)
storage/incoming/backgrounds/*
!storage/incoming/backgrounds/.gitkeep
storage/incoming/overlays/*
!storage/incoming/overlays/.gitkeep

# Original images dropped here for bulk import (public/views/bulk_import.php).
# Never committed — can be large/copyrighted; only the folder structure ships
# via .gitkeep. Converted output goes to public/v1/assets as .webp.
assets/original/backgrounds/*
!assets/original/backgrounds/.gitkeep
assets/original/overlays/*
!assets/original/overlays/.gitkeep

# Generated WebP assets served by the public API
public/v1/assets/*
!public/v1/assets/.gitkeep

# Fotos enviadas por clientes via links de upload (public/upload.php) — dados
# pessoais de clientes, nunca versionados. Servidas só por
# public/upload_link_photo.php (autenticado), nunca por URL direta.
storage/uploads/*
!storage/uploads/.gitkeep
keep
